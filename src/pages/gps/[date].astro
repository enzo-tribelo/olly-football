---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getEntry } from 'astro:content';
import { existsSync } from 'fs';

const BASE = import.meta.env.BASE_URL;
const SITE = 'https://or9.uk';

const clubLogos: Record<string, string> = {
  'Bath City U18': `${BASE}clubs/bath-city.png`,
  'Melksham Town U18': `${BASE}clubs/melksham-town.png`,
  'Melksham Town Reserves': `${BASE}clubs/melksham-town.png`,
};

const gpsEntry = await getEntry('gps', 'gps');
const allSessions = gpsEntry.data.sessions;

const { date } = Astro.params;
const s = allSessions.find(s => s.date === date);

if (!s || !s.has_data) return Astro.redirect(`${BASE}gps/`);

const validSessions = allSessions.filter(x => x.has_data);
const maxDist = Math.max(...validSessions.map(x => x.distance_m));
const fullMatchSessions = validSessions.filter(x => x.distance_m > maxDist * 0.5);
const avgPlayingMPM = fullMatchSessions.reduce((sum, x) => {
  return sum + x.metres_per_min * (x.duration_mins / (x.duration_mins - 15));
}, 0) / fullMatchSessions.length;
const estMins = Math.min(90, Math.round(s.distance_m / avgPlayingMPM));
const playingMins = s.actual_mins ?? estMins;
const isEstimate = !s.actual_mins;

const dateStr = new Date(s.date).toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
const canonicalURL = `${SITE}/gps/${s.date}/`;

// Speed zone breakdown (sorted fastest → slowest)
const zones = [
  { name: 'Sprint', distance: s.zone_sprint_distance_m, duration: s.zone_sprint_duration_s, events: s.zone_sprint_events, color: 'bg-red-500' },
  { name: 'High Speed Running', distance: s.zone_hs_running_distance_m, duration: s.zone_hs_running_duration_s, events: s.zone_hs_running_events, color: 'bg-orange-500' },
  { name: 'High Intensity', distance: s.zone_high_intensity_distance_m, duration: s.zone_high_intensity_duration_s, events: s.zone_high_intensity_events, color: 'bg-yellow-500' },
  { name: 'Medium Intensity', distance: s.zone_medium_distance_m, duration: s.zone_medium_duration_s, events: null, color: 'bg-green-500' },
  { name: 'Low Intensity', distance: s.zone_low_distance_m, duration: s.zone_low_duration_s, events: null, color: 'bg-blue-400' },
  { name: 'Jogging', distance: s.zone_jogging_distance_m, duration: s.zone_jogging_duration_s, events: null, color: 'bg-blue-300' },
];
const maxZoneDist = Math.max(...zones.map(z => z.distance));

const pageTitle = `${s.match} · ${dateStr} — GPS Performance | Olly Robinson`;
const pageDesc = `GPS data for Olly Robinson: ${s.match} on ${dateStr}. Top speed ${s.max_speed_kph} km/h, ${(s.distance_m/1000).toFixed(1)}km covered, ${s.sprints} sprints.`;

// Prev/next session navigation
const validDates = validSessions.map(x => x.date);
const currentIdx = validDates.indexOf(s.date);
const prevDate = currentIdx < validDates.length - 1 ? validDates[currentIdx + 1] : null;
const nextDate = currentIdx > 0 ? validDates[currentIdx - 1] : null;

// Heatmap images
const heatmapDir = 'public/gps/heatmaps';
const { statSync: fstatSync } = await import('fs');
const fileValid = (path: string, minSize = 2000) => {
  try { return existsSync(path) && fstatSync(path).size > minSize; } catch { return false; }
};
const firstHalfValid = fileValid(`${heatmapDir}/${s.date}-first-half.png`);
const secondHalfValid = fileValid(`${heatmapDir}/${s.date}-second-half.png`);
const firstHalfPaths = existsSync(`${heatmapDir}/${s.date}-first-half-paths.svg`);
const secondHalfPaths = existsSync(`${heatmapDir}/${s.date}-second-half-paths.svg`);

export async function getStaticPaths() {
  const gpsEntry = await getEntry('gps', 'gps');
  return gpsEntry.data.sessions
    .filter(s => s.has_data)
    .map(s => ({ params: { date: s.date } }));
}
---

<Layout title={pageTitle} description={pageDesc}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@ollyrobinson21" />
  </Fragment>

  <Nav current="gps" />

  <main id="main" class="min-h-screen pitch-pattern pt-20 pb-20"
    data-prev-url={prevDate ? `${BASE}gps/${prevDate}/` : ''}
    data-next-url={nextDate ? `${BASE}gps/${nextDate}/` : ''}>
    <Breadcrumb crumbs={[
      { label: 'Profile', href: '/' },
      { label: 'GPS Performance', href: '/gps/' },
      { label: `${s.match} · ${new Date(s.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}` }
    ]} />
    <div class="max-w-4xl mx-auto px-6 sm:px-10">

      <!-- Header -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-px w-12 bg-gold"></div>
          <span class="font-['Oswald'] text-xs uppercase tracking-[0.3em] text-gold">Match Session</span>
        </div>
        <h1 class="font-['Oswald'] text-4xl sm:text-5xl font-bold uppercase leading-tight tracking-tight mb-2 flex items-center gap-4">
          {clubLogos[s.match] && <img src={clubLogos[s.match]} alt={`${s.match} badge`} class="w-12 h-12 sm:w-14 sm:h-14 object-contain" width="56" height="56" />}
          <span class="text-cream">{s.match}</span>
        </h1>
        <p class="text-cream-muted text-sm">
          {dateStr} · <span class={`font-medium ${playingMins < 75 ? 'text-gold' : 'text-cream'}`}>{isEstimate ? '~' : ''}{playingMins} mins played</span>
        </p>
      </div>

      <!-- Session navigation -->
      <div class="flex items-center justify-between mb-10 py-3 border-y border-pitch-line/50">
        {prevDate ? (
          <a href={`${BASE}gps/${prevDate}/`} class="flex items-center gap-2 text-sm text-cream-muted hover:text-gold transition-colors group">
            <svg aria-hidden="true" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            <span>Previous Session</span>
          </a>
        ) : <span />}
        <a href={`${BASE}gps/`} class="text-xs text-cream-muted/60 hover:text-gold transition-colors uppercase tracking-widest">All Sessions</a>
        {nextDate ? (
          <a href={`${BASE}gps/${nextDate}/`} class="flex items-center gap-2 text-sm text-cream-muted hover:text-gold transition-colors group">
            <span>Next Session</span>
            <svg aria-hidden="true" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        ) : <span />}
      </div>

      <!-- Swipe hint — mobile only, fades after first view -->
      {(prevDate || nextDate) && (
        <div id="swipe-hint" class="flex items-center justify-center gap-3 mb-8 sm:hidden" aria-hidden="true">
          <span class="text-xs text-cream-muted/40 uppercase tracking-widest flex items-center gap-1.5">
            {prevDate && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>}
            Swipe to navigate
            {nextDate && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>}
          </span>
        </div>
      )}

      <!-- Key metrics — 4 big cards -->
      <section aria-label="Key metrics">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
          <div class="bg-surface-elevated/60 border border-gold/20 rounded-sm p-6 text-center">
            <div class="font-['Oswald'] text-4xl font-bold text-gold" aria-label={`Top speed ${s.max_speed_kph} kilometres per hour`}>{s.max_speed_kph}</div>
            <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Top Speed (km/h)</div>
          </div>
          <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-6 text-center">
            <div class="font-['Oswald'] text-4xl font-bold text-cream">{(s.distance_m / 1000).toFixed(1)}</div>
            <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Distance (km)</div>
          </div>
          <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-6 text-center">
            <div class="font-['Oswald'] text-4xl font-bold text-cream">{s.sprints}</div>
            <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Sprints</div>
          </div>
          <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-6 text-center">
            <div class="font-['Oswald'] text-4xl font-bold text-amber">{s.high_intensity}</div>
            <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">High Intensity</div>
          </div>
        </div>
      </section>

      <!-- Detailed stats grid -->
      <section aria-label="Performance detail">
        <h2 class="font-['Oswald'] text-2xl font-bold uppercase tracking-wide mb-6">Performance Detail</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-12">
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
            <div class="text-xs text-cream-muted uppercase tracking-wider">Avg Speed</div>
            <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.avg_speed_kph} <span class="text-sm text-cream-muted">km/h</span></div>
          </div>
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
            <div class="text-xs text-cream-muted uppercase tracking-wider">Metres / Min</div>
            <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.metres_per_min} <span class="text-sm text-cream-muted">m/min</span></div>
          </div>
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
            <div class="text-xs text-cream-muted uppercase tracking-wider">Sprint Distance</div>
            <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.sprint_distance_m} <span class="text-sm text-cream-muted">m</span></div>
          </div>
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
            <div class="text-xs text-cream-muted uppercase tracking-wider">High Speed Runs</div>
            <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.high_speed_run_events} <span class="text-sm text-cream-muted">({s.high_speed_distance_m}m)</span></div>
          </div>
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
            <div class="text-xs text-cream-muted uppercase tracking-wider">HI Distance</div>
            <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.high_intensity_distance_m} <span class="text-sm text-cream-muted">m</span></div>
          </div>
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
            <div class="text-xs text-cream-muted uppercase tracking-wider">Workload</div>
            <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.workload} <span class="text-sm text-cream-muted">/ {s.workload_intensity} int</span></div>
          </div>
        </div>
      </section>

      <!-- Acceleration -->
      <section aria-label="Acceleration and deceleration">
        <h2 class="font-['Oswald'] text-2xl font-bold uppercase tracking-wide mb-6">Acceleration & Deceleration</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-12">
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4 text-center">
            <div class="font-['Oswald'] text-2xl font-bold text-cream">{s.accelerations}</div>
            <div class="text-xs text-cream-muted uppercase tracking-wider mt-1">Accelerations</div>
          </div>
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4 text-center">
            <div class="font-['Oswald'] text-2xl font-bold text-cream">{s.decelerations}</div>
            <div class="text-xs text-cream-muted uppercase tracking-wider mt-1">Decelerations</div>
          </div>
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4 text-center">
            <div class="font-['Oswald'] text-2xl font-bold text-gold">{s.max_acceleration}</div>
            <div class="text-xs text-cream-muted uppercase tracking-wider mt-1">Max Accel (m/s²)</div>
          </div>
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4 text-center">
            <div class="font-['Oswald'] text-2xl font-bold text-fire">{s.max_deceleration}</div>
            <div class="text-xs text-cream-muted uppercase tracking-wider mt-1">Max Decel (m/s²)</div>
          </div>
        </div>
      </section>

      <!-- Heatmaps -->
      {(firstHalfValid || secondHalfValid) && (
        <section aria-label="Position heat maps">
          <h2 class="font-['Oswald'] text-2xl font-bold uppercase tracking-wide mb-6">Position Heat Map</h2>
          <div class={`grid ${firstHalfValid && secondHalfValid ? 'grid-cols-2' : 'grid-cols-1 max-w-xs mx-auto'} gap-4 mb-12`}>
            {firstHalfValid && (
              <div class="text-center">
                <div class="relative rounded-sm overflow-hidden">
                  <img src="/gps/heatmaps/pitch.png" alt="" class="w-full" width="1056" height="1600" loading="lazy" />
                  <img src={`/gps/heatmaps/${s.date}-first-half.png`} alt={`First half heat map for ${s.match}`} class="absolute inset-0 w-full h-full" />
                </div>
                <p class="text-xs text-cream-muted uppercase tracking-widest mt-2">1st Half</p>
              </div>
            )}
            {secondHalfValid && (
              <div class="text-center">
                <div class="relative rounded-sm overflow-hidden">
                  <img src="/gps/heatmaps/pitch.png" alt="" class="w-full" width="1056" height="1600" loading="lazy" />
                  <img src={`/gps/heatmaps/${s.date}-second-half.png`} alt={`Second half heat map for ${s.match}`} class="absolute inset-0 w-full h-full" />
                </div>
                <p class="text-xs text-cream-muted uppercase tracking-widest mt-2">2nd Half</p>
              </div>
            )}
          </div>
        </section>
      )}

      <!-- Sprint & Intensity Paths -->
      {(firstHalfPaths || secondHalfPaths) && (
        <section aria-label="Sprint and intensity paths">
          <h2 class="font-['Oswald'] text-2xl font-bold uppercase tracking-wide mb-2">Sprint & Intensity Map</h2>
          <div class="flex items-center gap-4 mb-6 text-xs text-cream-muted">
            <span class="flex items-center gap-1.5"><span class="w-4 h-0.5 bg-gold inline-block rounded"></span> Sprints</span>
            <span class="flex items-center gap-1.5"><span class="w-4 h-0.5 bg-amber inline-block rounded"></span> High Intensity</span>
            <span class="flex items-center gap-1.5"><span class="w-4 h-4 bg-pitch rounded-full border border-gold inline-flex items-center justify-center text-[6px] font-bold text-white leading-none">OR</span> Avg Position</span>
          </div>
          <div class={`grid ${firstHalfPaths && secondHalfPaths ? 'grid-cols-2' : 'grid-cols-1 max-w-xs mx-auto'} gap-4 mb-12`}>
            {firstHalfPaths && (
              <div class="text-center">
                <div class="relative rounded-sm overflow-hidden">
                  <img src="/gps/heatmaps/pitch.png" alt="" class="w-full" width="1056" height="1600" loading="lazy" />
                  <img src={`/gps/heatmaps/${s.date}-first-half-paths.svg`} alt={`First half sprint and intensity paths for ${s.match}`} class="absolute inset-0 w-full h-full" />
                </div>
                <p class="text-xs text-cream-muted uppercase tracking-widest mt-2">1st Half</p>
              </div>
            )}
            {secondHalfPaths && (
              <div class="text-center">
                <div class="relative rounded-sm overflow-hidden">
                  <img src="/gps/heatmaps/pitch.png" alt="" class="w-full" width="1056" height="1600" loading="lazy" />
                  <img src={`/gps/heatmaps/${s.date}-second-half-paths.svg`} alt={`Second half sprint and intensity paths for ${s.match}`} class="absolute inset-0 w-full h-full" />
                </div>
                <p class="text-xs text-cream-muted uppercase tracking-widest mt-2">2nd Half</p>
              </div>
            )}
          </div>
        </section>
      )}

      <!-- Speed Zones -->
      <section aria-label="Speed zones breakdown">
        <h2 class="font-['Oswald'] text-2xl font-bold uppercase tracking-wide mb-6">Speed Zones</h2>
        <div class="space-y-3 mb-12" role="list" aria-label="Speed zone breakdown">
          {zones.map(z => (
            <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4" role="listitem">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-3">
                  <div class={`w-3 h-3 rounded-full ${z.color}`} aria-hidden="true"></div>
                  <span class="font-['Oswald'] text-sm uppercase tracking-wide text-cream">{z.name}</span>
                </div>
                <div class="flex items-center gap-4 text-xs text-cream-muted">
                  <span>{z.distance}m</span>
                  <span>{Math.round(z.duration / 60)}:{String(Math.round(z.duration % 60)).padStart(2, '0')} min</span>
                  {z.events !== null && <span>{z.events} events</span>}
                </div>
              </div>
              <div class="w-full bg-pitch-line/30 rounded-full h-2" role="progressbar" aria-valuenow={z.distance} aria-valuemax={maxZoneDist} aria-label={`${z.name}: ${z.distance} metres`}>
                <div class={`${z.color} h-2 rounded-full`} style={`width: ${Math.max(2, (z.distance / maxZoneDist) * 100)}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Data source -->
      <footer class="text-center text-xs text-cream-muted/60">
        Data tracked via <a href="https://playerdata.com" target="_blank" rel="noopener noreferrer" class="text-gold/60 hover:text-gold underline">PlayerData</a> GPS
      </footer>

    </div>
  </main>

<script>
  (function () {
    const main = document.getElementById('main');
    if (!main) return;

    const prevUrl = main.dataset.prevUrl || '';
    const nextUrl = main.dataset.nextUrl || '';
    if (!prevUrl && !nextUrl) return;

    let startX = 0;
    let startY = 0;
    let navigating = false;

    main.addEventListener('touchstart', function (e) {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      navigating = false;
    }, { passive: true });

    main.addEventListener('touchend', function (e) {
      if (navigating) return;

      const deltaX = e.changedTouches[0].clientX - startX;
      const deltaY = e.changedTouches[0].clientY - startY;

      // Require horizontal swipe > 60px and more horizontal than vertical
      if (Math.abs(deltaX) < 60 || Math.abs(deltaX) < Math.abs(deltaY) * 1.5) return;

      navigating = true;

      if (deltaX < 0 && nextUrl) {
        // Swipe left → next session (newer)
        window.location.href = nextUrl;
      } else if (deltaX > 0 && prevUrl) {
        // Swipe right → previous session (older)
        window.location.href = prevUrl;
      } else {
        navigating = false;
      }
    }, { passive: true });

    // Swipe hint: hide after 4s, and don't show again this session
    const hint = document.getElementById('swipe-hint');
    if (hint) {
      if (sessionStorage.getItem('gps-swipe-seen')) {
        hint.style.display = 'none';
      } else {
        hint.style.transition = 'opacity 0.8s ease';
        setTimeout(function () {
          hint.style.opacity = '0';
          setTimeout(function () { hint.style.display = 'none'; }, 800);
        }, 3000);
        sessionStorage.setItem('gps-swipe-seen', '1');
      }
    }
  })();
</script>

</Layout>
