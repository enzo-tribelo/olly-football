---
import Layout from '../../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const BASE = import.meta.env.BASE_URL;

const gpsEntry = await getEntry('gps', 'gps');
const allSessions = gpsEntry.data.sessions;

const { id } = Astro.params;
const s = allSessions.find(s => s.session_id === id);

if (!s || !s.has_data) return Astro.redirect(`${BASE}gps/`);

const dateStr = new Date(s.date).toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

// Speed zone breakdown (sorted fastest → slowest)
const zones = [
  { name: 'Sprint', distance: s.zone_sprint_distance_m, duration: s.zone_sprint_duration_s, events: s.zone_sprint_events, color: 'bg-red-500' },
  { name: 'High Speed Running', distance: s.zone_hs_running_distance_m, duration: s.zone_hs_running_duration_s, events: s.zone_hs_running_events, color: 'bg-orange-500' },
  { name: 'High Intensity', distance: s.zone_high_intensity_distance_m, duration: s.zone_high_intensity_duration_s, events: s.zone_high_intensity_events, color: 'bg-yellow-500' },
  { name: 'Medium Intensity', distance: s.zone_medium_distance_m, duration: s.zone_medium_duration_s, events: null, color: 'bg-green-500' },
  { name: 'Low Intensity', distance: s.zone_low_distance_m, duration: s.zone_low_duration_s, events: null, color: 'bg-blue-400' },
  { name: 'Jogging', distance: s.zone_jogging_distance_m, duration: s.zone_jogging_duration_s, events: null, color: 'bg-blue-300' },
];
const maxZoneDist = Math.max(...zones.map(z => z.distance));

export async function getStaticPaths() {
  const gpsEntry = await getEntry('gps', 'gps');
  return gpsEntry.data.sessions
    .filter(s => s.has_data)
    .map(s => ({ params: { id: s.session_id } }));
}
---

<Layout title={`${s.match} · ${dateStr} — GPS`} description={`GPS performance data for ${s.match} on ${dateStr}`}>

  <nav aria-label="Session navigation" class="fixed top-0 left-0 right-0 z-50 bg-pitch/80 backdrop-blur-md border-b border-pitch-line/50">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 h-14 flex items-center justify-between">
      <a href={`${BASE}gps/`} class="font-['Oswald'] text-sm uppercase tracking-[0.3em] text-gold hover:text-cream transition-colors">← GPS Data</a>
      <span class="font-['Oswald'] text-sm uppercase tracking-[0.3em] text-cream-muted">{s.date}</span>
    </div>
  </nav>

  <main id="main" class="min-h-screen pitch-pattern pt-24 pb-20">
    <div class="max-w-4xl mx-auto px-6 sm:px-10">

      <!-- Header -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-px w-12 bg-gold"></div>
          <span class="font-['Oswald'] text-xs uppercase tracking-[0.3em] text-gold">Match Session</span>
        </div>
        <h1 class="font-['Oswald'] text-4xl sm:text-5xl font-bold uppercase leading-tight tracking-tight mb-2">
          <span class="text-cream">{s.match}</span>
        </h1>
        <p class="text-cream-muted text-sm">{dateStr} · {s.duration_mins} minutes</p>
      </div>

      <!-- Key metrics — 4 big cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        <div class="bg-surface-elevated/60 border border-gold/20 rounded-sm p-6 text-center">
          <div class="font-['Oswald'] text-4xl font-bold text-gold">{s.max_speed_kph}</div>
          <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Top Speed (km/h)</div>
        </div>
        <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-6 text-center">
          <div class="font-['Oswald'] text-4xl font-bold text-cream">{(s.distance_m / 1000).toFixed(1)}</div>
          <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Distance (km)</div>
        </div>
        <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-6 text-center">
          <div class="font-['Oswald'] text-4xl font-bold text-cream">{s.sprints}</div>
          <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Sprints</div>
        </div>
        <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-6 text-center">
          <div class="font-['Oswald'] text-4xl font-bold text-fire">{s.high_intensity}</div>
          <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">High Intensity</div>
        </div>
      </div>

      <!-- Detailed stats grid -->
      <h2 class="font-['Oswald'] text-2xl font-bold uppercase tracking-wide mb-6">Performance Detail</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-12">
        <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
          <div class="text-xs text-cream-muted uppercase tracking-wider">Avg Speed</div>
          <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.avg_speed_kph} <span class="text-sm text-cream-muted">km/h</span></div>
        </div>
        <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
          <div class="text-xs text-cream-muted uppercase tracking-wider">Metres / Min</div>
          <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.metres_per_min} <span class="text-sm text-cream-muted">m/min</span></div>
        </div>
        <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
          <div class="text-xs text-cream-muted uppercase tracking-wider">Sprint Distance</div>
          <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.sprint_distance_m} <span class="text-sm text-cream-muted">m</span></div>
        </div>
        <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
          <div class="text-xs text-cream-muted uppercase tracking-wider">High Speed Runs</div>
          <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.high_speed_run_events} <span class="text-sm text-cream-muted">({s.high_speed_distance_m}m)</span></div>
        </div>
        <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
          <div class="text-xs text-cream-muted uppercase tracking-wider">HI Distance</div>
          <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.high_intensity_distance_m} <span class="text-sm text-cream-muted">m</span></div>
        </div>
        <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
          <div class="text-xs text-cream-muted uppercase tracking-wider">Workload</div>
          <div class="font-['Oswald'] text-2xl font-bold text-cream mt-1">{s.workload} <span class="text-sm text-cream-muted">/ {s.workload_intensity} int</span></div>
        </div>
      </div>

      <!-- Acceleration -->
      <h2 class="font-['Oswald'] text-2xl font-bold uppercase tracking-wide mb-6">Acceleration & Deceleration</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-12">
        <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4 text-center">
          <div class="font-['Oswald'] text-2xl font-bold text-cream">{s.accelerations}</div>
          <div class="text-xs text-cream-muted uppercase tracking-wider mt-1">Accelerations</div>
        </div>
        <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4 text-center">
          <div class="font-['Oswald'] text-2xl font-bold text-cream">{s.decelerations}</div>
          <div class="text-xs text-cream-muted uppercase tracking-wider mt-1">Decelerations</div>
        </div>
        <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4 text-center">
          <div class="font-['Oswald'] text-2xl font-bold text-gold">{s.max_acceleration}</div>
          <div class="text-xs text-cream-muted uppercase tracking-wider mt-1">Max Accel (m/s²)</div>
        </div>
        <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4 text-center">
          <div class="font-['Oswald'] text-2xl font-bold text-fire">{s.max_deceleration}</div>
          <div class="text-xs text-cream-muted uppercase tracking-wider mt-1">Max Decel (m/s²)</div>
        </div>
      </div>

      <!-- Speed Zones -->
      <h2 class="font-['Oswald'] text-2xl font-bold uppercase tracking-wide mb-6">Speed Zones</h2>
      <div class="space-y-3 mb-12">
        {zones.map(z => (
          <div class="bg-surface-elevated/40 border border-pitch-line rounded-sm p-4">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-3">
                <div class={`w-3 h-3 rounded-full ${z.color}`}></div>
                <span class="font-['Oswald'] text-sm uppercase tracking-wide text-cream">{z.name}</span>
              </div>
              <div class="flex items-center gap-4 text-xs text-cream-muted">
                <span>{z.distance}m</span>
                <span>{Math.round(z.duration / 60)}:{String(Math.round(z.duration % 60)).padStart(2, '0')} min</span>
                {z.events !== null && <span>{z.events} events</span>}
              </div>
            </div>
            <div class="w-full bg-pitch-line/30 rounded-full h-2">
              <div class={`${z.color} h-2 rounded-full`} style={`width: ${Math.max(2, (z.distance / maxZoneDist) * 100)}%`}></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Data source -->
      <div class="text-center text-xs text-cream-muted/60">
        Data tracked via <a href="https://playerdata.com" target="_blank" rel="noopener" class="text-gold/60 hover:text-gold underline">PlayerData</a> GPS
      </div>

    </div>
  </main>

</Layout>
