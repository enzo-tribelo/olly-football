---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getEntry } from 'astro:content';

const BASE = import.meta.env.BASE_URL;

const clubLogos: Record<string, string> = {
  'Bath City U18': `${BASE}clubs/bath-city.png`,
  'Melksham Town U18': `${BASE}clubs/melksham-town.png`,
  'Melksham Town Reserves': `${BASE}clubs/melksham-town.png`,
};

const gpsEntry = await getEntry('gps', 'gps');
const allSessions = gpsEntry.data.sessions;
const validSessions = allSessions.filter(s => s.has_data);

// Estimate playing time:
// 1. Correct API m/min by removing 15min halftime dilution
// 2. Use only "full match" sessions (>50% max distance) for baseline
// 3. Estimate each session's playing time from avg corrected m/min
const maxDist = Math.max(...validSessions.map(s => s.distance_m));
const fullMatchSessions = validSessions.filter(s => s.distance_m > maxDist * 0.5);
const avgPlayingMPM = fullMatchSessions.reduce((sum, s) => {
  const corrected = s.metres_per_min * (s.duration_mins / (s.duration_mins - 15));
  return sum + corrected;
}, 0) / fullMatchSessions.length;

const sessionsWithEst = allSessions.map(s => {
  const est = s.has_data ? Math.min(90, Math.round(s.distance_m / avgPlayingMPM)) : 0;
  const mins = s.actual_mins ?? est;
  const isEstimate = !s.actual_mins;
  return { ...s, playing_mins: mins, is_estimate: isEstimate };
});

const stats = {
  tracked: allSessions.length,
  withData: validSessions.length,
  topSpeed: Math.max(...validSessions.map(s => s.max_speed_kph)),
  avgDistance: Math.round(validSessions.reduce((sum, s) => sum + s.distance_m, 0) / validSessions.length),
  avgSprints: Math.round(validSessions.reduce((sum, s) => sum + s.sprints, 0) / validSessions.length),
  avgHighIntensity: Math.round(validSessions.reduce((sum, s) => sum + s.high_intensity, 0) / validSessions.length),
  totalDistance: Math.round(validSessions.reduce((sum, s) => sum + s.distance_m, 0)),
  avgHighSpeedDist: Math.round(validSessions.reduce((sum, s) => sum + s.high_speed_distance_m, 0) / validSessions.length),
  avgSpeed: Math.round(validSessions.reduce((sum, s) => sum + s.avg_speed_kph, 0) / validSessions.length * 10) / 10,
};
---

<Layout title="GPS Performance — Olly Robinson | Striker" description="GPS tracking data for Olly Robinson — distance, top speed, sprints and high-intensity performance tracked via PlayerData. Bath City U18, 2025-26 season.">
  <Fragment slot="head">
    <link rel="canonical" href="https://or9.uk/gps/" />
    <meta property="og:title" content="GPS Performance — Olly Robinson" />
    <meta property="og:description" content="GPS tracking data for Olly Robinson — distance, top speed, sprints and high-intensity performance. Bath City U18, 2025-26." />
    <meta property="og:url" content="https://or9.uk/gps/" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@ollyrobinson21" />
  </Fragment>

  <Nav current="gps" />

  <main id="main" class="min-h-screen pitch-pattern pt-20 pb-20">
    <Breadcrumb crumbs={[{ label: 'Profile', href: '/' }, { label: 'GPS Performance' }]} />
    <div class="max-w-5xl mx-auto px-6 sm:px-10">

      <!-- Header -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px w-12 bg-gold"></div>
          <span class="font-['Oswald'] text-xs uppercase tracking-[0.3em] text-gold">PlayerData GPS Tracking</span>
        </div>
        <h1 class="font-['Oswald'] text-5xl sm:text-6xl lg:text-7xl font-bold uppercase leading-[0.85] tracking-tight mb-4">
          <span class="text-cream">GPS</span> <span class="text-gold">Data</span>
        </h1>
        <p class="text-cream-muted text-sm max-w-lg">
          Physical performance data tracked via PlayerData GPS vests during Bath City U18 matches · 2025-26 season · {stats.tracked} sessions tracked, {stats.withData} with data.
        </p>
      </div>

      <!-- Headline stats grid -->
      <section aria-label="Season averages" class="mb-14">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        <div class="bg-surface-elevated/60 border border-gold/20 rounded-sm p-5 text-center">
          <div class="font-['Oswald'] text-3xl font-bold text-gold">{stats.topSpeed}</div>
          <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Top Speed<br/>km/h</div>
        </div>
        <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-5 text-center">
          <div class="font-['Oswald'] text-3xl font-bold text-cream">{(stats.avgDistance / 1000).toFixed(1)}</div>
          <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Avg Distance<br/>km</div>
        </div>
        <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-5 text-center">
          <div class="font-['Oswald'] text-3xl font-bold text-cream">{stats.avgSprints}</div>
          <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Avg Sprints<br/>per match</div>
        </div>
        <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-5 text-center">
          <div class="font-['Oswald'] text-3xl font-bold text-amber">{stats.avgHighIntensity}</div>
          <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Avg High<br/>Intensity</div>
        </div>
        <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-5 text-center">
          <div class="font-['Oswald'] text-3xl font-bold text-cream">{stats.avgHighSpeedDist}</div>
          <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Avg HS Run<br/>metres</div>
        </div>
        <div class="bg-surface-elevated/60 border border-pitch-line rounded-sm p-5 text-center">
          <div class="font-['Oswald'] text-3xl font-bold text-cream">{(stats.totalDistance / 1000).toFixed(1)}</div>
          <div class="text-xs text-cream-muted uppercase tracking-widest mt-1">Total Distance<br/>km</div>
        </div>
      </div>

      </section>

      <!-- Session-by-session -->
      <section aria-label="Match sessions">
      <h2 class="font-['Oswald'] text-2xl font-bold uppercase tracking-wide mb-6">Match Sessions</h2>

      <div class="space-y-4" role="list">
        {sessionsWithEst.map(s => (
          <a href={s.has_data ? `${BASE}gps/${s.date}/` : undefined} role="listitem" aria-label={s.has_data ? `${s.match} on ${s.date} — view full GPS data` : `${s.match} on ${s.date} — no GPS data`} class={`block border rounded-sm p-5 transition-all ${s.has_data ? 'bg-surface-elevated/40 border-pitch-line hover:border-gold/40 hover:bg-surface-elevated/60 cursor-pointer' : 'bg-surface-elevated/20 border-pitch-line/50 opacity-50 pointer-events-none'}`}>
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
              <div>
                <div class="font-['Oswald'] text-base uppercase tracking-wide text-cream flex items-center gap-2">
                  {clubLogos[s.match] && <img src={clubLogos[s.match]} alt="" class="w-6 h-6 object-contain" width="24" height="24" loading="lazy" />}
                  {s.match}
                </div>
                <div class="text-xs text-cream-muted flex items-center gap-3">
                  <span>{new Date(s.date).toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' })}</span>
                  <span>·</span>
                  {s.has_data ? (
                    <span class={s.playing_mins < 75 ? 'text-gold font-medium' : ''}>
                      {s.is_estimate ? '~' : ''}{s.playing_mins} mins played
                    </span>
                  ) : (
                    <span class="text-fire/80 font-medium">No GPS data</span>
                  )}
                </div>
                {s.ai_tagline && (
                  <p class="text-xs text-cream-muted/70 italic mt-1">{s.ai_tagline}</p>
                )}
              </div>
              {s.has_data && (
                <div class="grid grid-cols-3 sm:grid-cols-5 gap-4 sm:gap-6 text-center">
                  <div>
                    <div class="font-['Oswald'] text-xl font-bold text-cream">{(s.distance_m / 1000).toFixed(1)}<span class="text-sm text-cream-muted">km</span></div>
                    <div class="text-xs text-cream-muted">Distance</div>
                  </div>
                  <div>
                    <div class="font-['Oswald'] text-xl font-bold text-gold">{s.max_speed_kph}<span class="text-sm text-cream-muted">km/h</span></div>
                    <div class="text-xs text-cream-muted">Top Speed</div>
                  </div>
                  <div>
                    <div class="font-['Oswald'] text-xl font-bold text-cream">{s.avg_speed_kph}<span class="text-sm text-cream-muted">km/h</span></div>
                    <div class="text-xs text-cream-muted">Avg Speed</div>
                  </div>
                  <div>
                    <div class="font-['Oswald'] text-xl font-bold text-cream">{s.sprints}</div>
                    <div class="text-xs text-cream-muted">Sprints</div>
                  </div>
                  <div>
                    <div class="font-['Oswald'] text-xl font-bold text-amber">{s.high_intensity}</div>
                    <div class="text-xs text-cream-muted">High Intensity</div>
                  </div>
                </div>
              )}
            </div>
            {s.has_data && (
              <div class="mt-4 pt-3 border-t border-pitch-line/50 flex items-center justify-between">
                <div class="flex gap-6 text-xs text-cream-muted">
                  <span>High-speed running: <span class="text-cream font-medium">{s.high_speed_distance_m}m</span></span>
                  <span>Avg speed: <span class="text-cream font-medium">{s.avg_speed_kph} km/h</span></span>
                </div>
                <span class="inline-flex items-center gap-1.5 text-sm text-gold font-['Oswald'] uppercase tracking-wider">
                  View Detail
                  <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                </span>
              </div>
            )}
          </a>
        ))}
      </div>
      </section>

      <!-- Data source -->
      <footer class="mt-12 text-center text-xs text-cream-muted/60">
        Data tracked via <a href="https://playerdata.com" target="_blank" rel="noopener noreferrer" class="text-gold/60 hover:text-gold underline">PlayerData</a> GPS · Updated weekly
      </footer>

    </div>
  </main>

</Layout>
