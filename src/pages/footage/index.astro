---
import Layout from '../../layouts/Layout.astro';

const BASE = import.meta.env.BASE_URL;

const videos = [
  { id: '6YTtkB6Qh_g', title: 'Melksham Town vs Chippenham Town — Clip', description: 'Melksham Town Reserves · 2025-26', type: 'match' },
  { id: 'TMCEEEKN_fk', title: 'Calne U16 vs Swindon Supermarine — Goal', description: 'September 2024', type: 'match' },
  { id: '6XvCLzA53YM', title: 'Dutch International Tournament — Clips (1)', description: 'Summer 2024', type: 'highlight' },
  { id: 'C_TTKECG0Cc', title: 'Dutch International Tournament — Clips (2)', description: 'Summer 2024', type: 'highlight' },
  { id: 'KkvmGcuv8nE', title: 'AFC Corsham U15 vs Bradford — Cup Final Goals', description: 'Cup Final 2023-24', type: 'match' },
  { id: 'LhVojvKhg2U', title: 'JPL Goal of the Month — FC Wilts U15', description: 'October 2023', type: 'highlight' },
];

const typeColors: Record<string, string> = {
  highlight: 'bg-gold/10 text-gold border-gold/20',
  match: 'bg-fire/10 text-fire border-fire/20',
  training: 'bg-blue-500/10 text-blue-400 border-blue-400/20',
};
---

<Layout title="Footage — Olly Robinson" description="Match footage, highlights and goals for Olly Robinson — Striker.">

  <nav aria-label="Footage navigation" class="fixed top-0 left-0 right-0 z-50 bg-pitch/80 backdrop-blur-md border-b border-pitch-line/50">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 h-14 flex items-center justify-between">
      <a href={BASE} class="font-['Oswald'] text-sm uppercase tracking-[0.3em] text-gold hover:text-cream transition-colors">← Back to Profile</a>
      <span class="font-['Oswald'] text-sm uppercase tracking-[0.3em] text-cream-muted">Footage & Clips</span>
    </div>
  </nav>

  <main id="main" class="min-h-screen pitch-pattern pt-24 pb-20">
    <div class="max-w-4xl mx-auto px-6 sm:px-10">

      <!-- Header -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px w-12 bg-gold"></div>
          <span class="font-['Oswald'] text-xs uppercase tracking-[0.3em] text-gold">Match Footage & Highlights</span>
        </div>
        <h1 class="font-['Oswald'] text-5xl sm:text-6xl lg:text-7xl font-bold uppercase leading-[0.85] tracking-tight mb-4">
          <span class="text-cream">Watch</span> <span class="text-gold">Olly</span>
        </h1>
        <p class="text-cream-muted text-sm max-w-lg">
          Match highlights, goals and tournament clips.
        </p>
      </div>

      <!-- Video List — single column, full width -->
      <div class="space-y-10">
        {videos.map(v => (
          <div class="group">
            <!-- Thumbnail with play button — click to load iframe -->
            <button type="button" aria-label={`Play video: ${v.title}`} class="relative aspect-video w-full rounded-sm overflow-hidden bg-pitch-light cursor-pointer video-container focus:outline-2 focus:outline-gold focus:outline-offset-2" data-video-id={v.id} data-video-title={v.title}>
              <img
                src={`https://img.youtube.com/vi/${v.id}/hqdefault.jpg`}
                alt={v.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-pitch/30 group-hover:bg-pitch/10 transition-colors flex items-center justify-center">
                <div class="w-16 h-16 sm:w-20 sm:h-20 bg-gold/90 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform shadow-lg shadow-gold/20">
                  <svg class="w-7 h-7 sm:w-8 sm:h-8 text-pitch ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </button>
            <!-- Info -->
            <div class="flex items-center gap-3 mt-4">
              <span class={`text-xs font-semibold uppercase tracking-wider border px-2 py-0.5 rounded-sm ${typeColors[v.type]}`}>{v.type}</span>
              <h3 class="font-['Oswald'] text-lg uppercase tracking-wide text-cream">{v.title}</h3>
            </div>
            <p class="text-xs text-cream-muted mt-1">{v.description}</p>
          </div>
        ))}
      </div>

      <!-- More coming -->
      <div class="mt-16 text-center border border-dashed border-pitch-line rounded-sm p-10">
        <div class="font-['Oswald'] text-xl uppercase tracking-wide text-cream-muted mb-2">More footage coming soon</div>
        <p class="text-xs text-cream-muted">Full match recordings and new highlight reels will be added throughout the season.</p>
      </div>

    </div>
  </main>

</Layout>

<script>
  // Click thumbnail to replace with YouTube iframe — only one plays at a time
  let activeContainer: HTMLElement | null = null;
  let activeOriginalHTML: string = '';

  document.querySelectorAll('.video-container').forEach(container => {
    const originalHTML = container.innerHTML;

    container.addEventListener('click', () => {
      const id = container.getAttribute('data-video-id');
      if (!id) return;

      // If clicking the already-active video, do nothing
      if (activeContainer === container) return;

      // Stop the currently playing video by restoring its thumbnail
      if (activeContainer) {
        activeContainer.innerHTML = activeOriginalHTML;
        activeContainer.classList.add('cursor-pointer');
      }

      // Store reference and original HTML
      activeContainer = container as HTMLElement;
      activeOriginalHTML = originalHTML;

      // Replace with iframe
      const title = container.getAttribute('data-video-title') || 'Video player';
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.setAttribute('title', title);
      iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
      iframe.setAttribute('allowfullscreen', '');
      iframe.className = 'w-full h-full absolute inset-0';
      container.innerHTML = '';
      container.style.position = 'relative';
      container.appendChild(iframe);
      container.classList.remove('cursor-pointer');
    });
  });
</script>
