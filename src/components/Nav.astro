---
interface Props {
  /** Current page identifier for active state */
  current?: 'home' | 'matches' | 'gps' | 'footage';
  /** Override left side with custom back link */
  backHref?: string;
  backLabel?: string;
  /** Extra center/right content (e.g. prev/next nav) */
  centerSlot?: string;
}

const BASE = import.meta.env.BASE_URL;
const { current = 'home', backHref, backLabel } = Astro.props;

const links = [
  { href: `${BASE}#stats`, label: 'Stats', page: 'home' },
  { href: `${BASE}#seasons`, label: 'Seasons', page: 'home' },
  { href: `${BASE}#honours`, label: 'Honours', page: 'home' },
  { href: `${BASE}#gallery`, label: 'Gallery', page: 'home' },
  { href: `${BASE}matches/`, label: 'Matches', page: 'matches' },
  { href: `${BASE}gps/`, label: 'GPS', page: 'gps' },
  { href: `${BASE}footage/`, label: 'Footage', page: 'footage' },
];
---

<!-- Desktop nav -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-pitch/80 backdrop-blur-md border-b border-pitch-line/50 hidden md:block" aria-label="Site navigation">
  <div class="max-w-7xl mx-auto px-6 sm:px-10 h-14 flex items-center justify-between">
    <a href={BASE} class="font-['Oswald'] text-sm uppercase tracking-[0.3em] text-gold hover:text-cream transition-colors">OR<span class="text-cream/40">9</span></a>
    <div class="flex items-center gap-6">
      <slot name="center" />
      {links.map(link => (
        link.cta
          ? <a href={link.href} class={`text-xs uppercase tracking-widest font-semibold px-4 py-1.5 rounded-sm transition-colors ${current === link.page ? 'bg-gold-dim text-pitch' : 'bg-gold text-pitch hover:bg-gold-dim'}`}>{link.label}</a>
          : <a href={link.href} class={`text-xs uppercase tracking-widest font-medium transition-colors ${current === link.page ? 'text-gold' : 'text-cream-muted hover:text-gold'}`}>{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<!-- Mobile FAB hamburger -->
<button id="mobile-fab" class="md:hidden fixed bottom-6 right-6 z-50 w-14 h-14 bg-gold rounded-full flex items-center justify-center shadow-lg shadow-gold/20 active:scale-95 transition-transform" aria-label="Menu">
  <svg aria-hidden="true" id="fab-open" class="w-6 h-6 text-pitch" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
  <svg aria-hidden="true" id="fab-close" class="w-6 h-6 text-pitch hidden" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
</button>

<!-- Mobile menu -->
<div id="mobile-menu" class="md:hidden fixed bottom-24 right-6 z-50 flex flex-col gap-2 items-end opacity-0 pointer-events-none transition-all duration-200 translate-y-4">
  {current !== 'home' && (
    <a href={BASE} class="mobile-nav-link px-5 py-2.5 bg-surface-elevated/95 backdrop-blur border border-pitch-line rounded-full text-xs font-['Oswald'] uppercase tracking-widest transition-all text-cream hover:text-gold hover:border-gold/30">Home</a>
  )}
  {links.map(link => (
    link.cta
      ? <a href={link.href} class={`mobile-nav-link px-5 py-2.5 rounded-full text-xs font-['Oswald'] uppercase tracking-widest font-semibold transition-all ${current === link.page ? 'bg-gold-dim text-pitch' : 'bg-gold text-pitch hover:bg-gold-dim'}`}>{link.label}</a>
      : <a href={link.href} class={`mobile-nav-link px-5 py-2.5 bg-surface-elevated/95 backdrop-blur border border-pitch-line rounded-full text-xs font-['Oswald'] uppercase tracking-widest transition-all ${current === link.page ? 'text-gold border-gold/30' : 'text-cream hover:text-gold hover:border-gold/30'}`}>{link.label}</a>
  ))}
</div>

<!-- Share button: mobile = above FAB (bottom-right), desktop = below nav (top-right) -->
<button id="share-btn" aria-label="Share this page" class="fixed z-40 w-11 h-11 bg-surface-elevated/90 backdrop-blur border border-pitch-line rounded-full flex items-center justify-center text-cream-muted hover:text-gold hover:border-gold/40 transition-all cursor-pointer focus:outline-2 focus:outline-gold focus:outline-offset-2 bottom-[5.5rem] right-6 md:bottom-auto md:top-[4.25rem] md:right-6">
  <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16"><path d="M12,9.7c-0.9,0-1.6,0.4-2.2,1L6.8,8.9C6.9,8.6,6.9,8.3,6.9,8c0-0.3,0-0.6-0.1-0.9l3.1-1.8c0.5,0.6,1.3,1,2.2,1c1.7,0,3-1.4,3-3.1C15,1.4,13.7,0,12,0c-1.7,0-3,1.4-3,3.1c0,0.3,0,0.6,0.1,0.9L6.1,5.9c-0.5-0.6-1.3-1-2.2-1C2.3,4.9,1,6.3,1,8c0,1.7,1.3,3.1,3,3.1c0.9,0,1.6-0.4,2.2-1L9.2,12c-0.1,0.3-0.1,0.6-0.1,0.9c0,1.7,1.3,3.1,3,3.1c1.7,0,3-1.4,3-3.1C15,11.1,13.7,9.7,12,9.7z"/></svg>
</button>
<!-- Share toast -->
<div id="share-toast" class="fixed z-50 bg-gold text-pitch text-xs font-semibold px-4 py-2 rounded-sm opacity-0 pointer-events-none transition-opacity duration-300 bottom-[8rem] right-6 md:bottom-auto md:top-[4.25rem] md:right-[4.5rem]">Link copied!</div>

<!-- Back to top -->
<button id="back-to-top" aria-label="Back to top" class="fixed bottom-6 left-6 z-40 w-11 h-11 bg-surface-elevated/90 backdrop-blur border border-pitch-line rounded-full flex items-center justify-center text-cream-muted hover:text-gold hover:border-gold/40 transition-all opacity-0 pointer-events-none cursor-pointer focus:outline-2 focus:outline-gold focus:outline-offset-2">
  <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
</button>

<script>
  // Mobile FAB menu toggle
  const fab = document.getElementById('mobile-fab');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('fab-open');
  const closeIcon = document.getElementById('fab-close');
  let menuOpen = false;

  fab?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      menu?.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
      menu?.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    } else {
      menu?.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
      menu?.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  });

  // Close menu on nav click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menuOpen = false;
      menu?.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
      menu?.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });

  // Share button
  const shareBtn = document.getElementById('share-btn');
  const shareToast = document.getElementById('share-toast');
  shareBtn?.addEventListener('click', async () => {
    const url = window.location.href;
    const title = document.title;
    if (navigator.share) {
      try { await navigator.share({ title, url }); } catch {}
    } else if (navigator.clipboard) {
      await navigator.clipboard.writeText(url);
      shareToast?.classList.remove('opacity-0');
      setTimeout(() => shareToast?.classList.add('opacity-0'), 2000);
    }
  });

  // Back to top button
  const btt = document.getElementById('back-to-top');
  if (btt) {
    window.addEventListener('scroll', () => {
      const show = window.scrollY > 600;
      btt.classList.toggle('opacity-0', !show);
      btt.classList.toggle('pointer-events-none', !show);
    }, { passive: true });
    btt.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
